      "minimumSemester": 1,
      "required": true,
      "heavy": false,
      "manual": false,
      "mvpDefault": true,
      "verification": ["code --version"],
      "platforms": {
        "windows": {
          "manager": "winget",
          "id": "Microsoft.VisualStudioCode"
        },
        "macos": {
          "manager": "brew-cask",
          "id": "visual-studio-code"
        }
      }
    },
    {
      "key": "python",
