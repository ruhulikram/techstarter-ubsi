{
  "$schema": "./schema/packages.schema.json",
  "schemaVersion": "0.1.0",
  "packages": [
    {
      "key": "git",
      "name": "Git",
      "description": "Version control untuk praktikum, tugas, dan kolaborasi source code.",
      "category": "developer-tool",
      "profiles": ["core"],
      "minimumSemester": 1,
      "required": true,
      "heavy": false,
      "manual": false,
      "mvpDefault": true,
      "verification": ["git --version"],
      "platforms": {
        "windows": {
          "manager": "winget",
          "id": "Git.Git"
        },
        "macos": {
          "manager": "brew",
          "id": "git"
        }
      }
    },
    {
      "key": "vscode",
      "name": "Visual Studio Code",
